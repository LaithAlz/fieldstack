# API base URL — read by src/api/client.ts (forthcoming).
# Keep `EXPO_PUBLIC_*` prefix so Expo inlines it into the JS bundle at build time.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase — same project the server points at. Anon key is safe in the
# client bundle; RLS policies enforce per-user access on the server.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# PostHog product analytics. Set the project API key to turn analytics on —
# without it the app stays on the no-op console provider (dev/CI). Find it in
# PostHog → Project settings → Project API Key (starts with `phc_`).
EXPO_PUBLIC_POSTHOG_KEY=
# Only needed for EU-hosted projects: https://eu.i.posthog.com (default is US).
EXPO_PUBLIC_POSTHOG_HOST=

# Sentry crash reporting DSN. Leave blank to disable (dev/CI). Sentry → Project
# settings → Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
