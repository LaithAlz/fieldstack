# Supabase
SUPABASE_URL=http://127.0.0.1:54321
# Anon key — safe to ship; the API uses it so RLS policies apply.
SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Bypasses RLS. Used by scripts/seed.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Redis (proximity-search cache)
REDIS_URL=redis://127.0.0.1:6379

# API
PORT=3000
HOST=0.0.0.0
# Set to "true" ONLY when deployed behind a load balancer / reverse proxy so
# rate limiting sees the real client IP (X-Forwarded-For) instead of the
# proxy's. Leave unset for direct exposure — otherwise clients can spoof IPs.
TRUST_PROXY=
