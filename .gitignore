# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/

# Bun lockfile is intentionally NOT tracked — CI installs from the tracked
# package-lock.json, and committing bun.lock breaks the frozen-lockfile install.
bun.lock

# ---------------------------------------------------------------------------
# Env files — never commit; copy .env.example and fill in locally.
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Backend (Fastify + Supabase)
# ---------------------------------------------------------------------------
dist/
.supabase/
supabase/.temp/
supabase/.branches/

# ---------------------------------------------------------------------------
# Mobile (Expo / React Native)
# ---------------------------------------------------------------------------
.expo/
web-build/
expo-env.d.ts
.metro-health-check*
*.tsbuildinfo

# Native build artifacts (only present after `expo prebuild`)
/ios
/android
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ---------------------------------------------------------------------------
# Logs / debug
# ---------------------------------------------------------------------------
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ---------------------------------------------------------------------------
# OS / editor / agent state
# ---------------------------------------------------------------------------
.DS_Store
.idea/
# Claude harness state stays local, but the project skill library is tracked.
.claude/*
!.claude/skills/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Redis on-disk dump from local backend runs
dump.rdb
*.rdb

# Local agent scratch / handoff notes — never committed
_temp/
handoff/
ARCHITECT.md
BUILDER.md
REVIEWER.md
new-setup.md
