{
  "name": "fieldstack",
  "version": "0.0.1",
  "private": true,
  "description": "Soccer field discovery + booking aggregator for the GTA",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local --schema public > types/database.ts",
    "db:types:remote": "supabase gen types typescript --linked --schema public > types/database.ts",
    "seed": "tsx scripts/seed.ts",
    "scrape": "bun scripts/scrape/run.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "ws": "^8.18.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.13",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.2.2",
    "supabase": "^1.200.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
